# ClearPass Policy Manager connection
CLEARPASS_BASE_URL=https://clearpass.example.com
CLEARPASS_API_TOKEN=your-api-token-here
CLEARPASS_VERIFY_SSL=true

# SQLite database path (inside the container, maps to ./data/ on the host)
DB_PATH=/data/clearpass_visualizer.db

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Host-side port bindings (container-internal ports are fixed at 8000/80)
BACKEND_PORT=8000
FRONTEND_PORT=8081

# Dev server ports (vite only, not used by Docker)
VITE_DEV_PORT=5173
VITE_BACKEND_PORT=8000
